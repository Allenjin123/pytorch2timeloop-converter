  subgraph cluster_legend {
    label="Legend";
    fontsize=11;
    style="rounded";
    color="#CCCCCC";
    bgcolor="#F8F8F8";
    "leg_linear" [label="linear", shape=box, fillcolor="#4A90D9", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_conv2d" [label="conv2d", shape=box, fillcolor="#50B86C", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_pointwise_conv2d" [label="pointwise conv2d", shape=box, fillcolor="#7BC67B", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_depthwise_conv2d" [label="depthwise conv2d", shape=box, fillcolor="#2D8A4E", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_residual_add" [label="residual add", shape=circle, fillcolor="#E85454", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_linear" -> "leg_conv2d" -> "leg_pointwise_conv2d" -> "leg_depthwise_conv2d" -> "leg_residual_add" [style=invis];
    "leg_skip_src" [label="", shape=point, width=0.1];
    "leg_skip_dst" [label="skip conn.", shape=plaintext, fontsize=9];
    "leg_skip_src" -> "leg_skip_dst" [style=dashed, color="#E85454", penwidth=2.0];
    "leg_residual_add" -> "leg_skip_src" [style=invis];
  }
