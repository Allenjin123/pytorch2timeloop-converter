digraph G {
  label="llama3.1_8b_decode_kv2048";
  labelloc="t";
  fontsize=16;
  fontname="Helvetica";
  rankdir=TB;
  nodesep=0.4;
  ranksep=0.6;
  node [fontname="Helvetica", fontsize=10, style="filled,rounded", penwidth=1.5];
  edge [fontname="Helvetica", fontsize=8, color="#555555"];

  { rank=same; "layer0_k_proj" "layer0_q_proj" "layer0_v_proj" }
  { rank=same; "layer0_gate_proj" "layer0_up_proj" }

  "layer0_input" [label="input", shape=ellipse, fillcolor="#E8E8E8", style="filled"];
  "layer0_k_proj" [label="k_proj\n4096x1024", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_q_proj" [label="q_proj\n4096x4096", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_attn_qk" [label="attn_qk\n1x2048", shape=diamond, fillcolor="#E8963E", fontcolor="white"];
  "layer0_softmax_max" [label="softmax_max\n1x2048", shape=parallelogram, fillcolor="#F5C842", fontcolor="white"];
  "layer0_softmax_exp" [label="softmax_exp\n1x2048", shape=parallelogram, fillcolor="#F0B429", fontcolor="white"];
  "layer0_softmax_sum" [label="softmax_sum\n1x2048", shape=parallelogram, fillcolor="#E8963E", fontcolor="white"];
  "layer0_softmax_div" [label="softmax_div\n1x2048", shape=parallelogram, fillcolor="#D4832C", fontcolor="white"];
  "layer0_v_proj" [label="v_proj\n4096x1024", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_attn_v" [label="attn_v\n1x2048", shape=diamond, fillcolor="#D4722C", fontcolor="white"];
  "layer0_o_proj" [label="o_proj\n4096x4096", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_attn_residual_add" [label="+", shape=circle, fillcolor="#E85454", width=0.3, height=0.3, fixedsize=true, fontsize=14];
  "layer0_gate_proj" [label="gate_proj\n4096x14336", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_up_proj" [label="up_proj\n4096x14336", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_down_proj" [label="down_proj\n14336x4096", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_mlp_residual_add" [label="+", shape=circle, fillcolor="#E85454", width=0.3, height=0.3, fixedsize=true, fontsize=14];
  "lm_head" [label="lm_head\n4096x128256", shape=box, fillcolor="#4A90D9", fontcolor="white"];

  "layer0_input" -> "layer0_q_proj" [label="[1x1x4096]", style=solid, color="#555555", penwidth=1.0];
  "layer0_input" -> "layer0_k_proj" [label="[1x1x4096]", style=solid, color="#555555", penwidth=1.0];
  "layer0_input" -> "layer0_v_proj" [label="[1x1x4096]", style=solid, color="#555555", penwidth=1.0];
  "layer0_q_proj" -> "layer0_attn_qk" [label="query\n[1x32x1x128]", style=solid, color="#555555", penwidth=1.0];
  "layer0_k_proj" -> "layer0_attn_qk" [label="key\n[1x32x2048x128]", style=solid, color="#555555", penwidth=1.0];
  "layer0_attn_qk" -> "layer0_softmax_max" [label="scores\n[1x32x1x2048]", style=solid, color="#555555", penwidth=1.0];
  "layer0_softmax_max" -> "layer0_softmax_exp" [label="scores_max\n[1x32x1x2048]", style=solid, color="#555555", penwidth=1.0];
  "layer0_softmax_exp" -> "layer0_softmax_sum" [label="scores_exp\n[1x32x1x2048]", style=solid, color="#555555", penwidth=1.0];
  "layer0_softmax_sum" -> "layer0_softmax_div" [label="scores_sum\n[1x32x1x2048]", style=solid, color="#555555", penwidth=1.0];
  "layer0_softmax_div" -> "layer0_attn_v" [label="attn_weights\n[1x32x1x2048]", style=solid, color="#555555", penwidth=1.0];
  "layer0_v_proj" -> "layer0_attn_v" [label="value\n[1x32x2048x128]", style=solid, color="#555555", penwidth=1.0];
  "layer0_attn_v" -> "layer0_o_proj" [label="attn_output\n[1x1x4096]", style=solid, color="#555555", penwidth=1.0];
  "layer0_o_proj" -> "layer0_attn_residual_add" [label="o_proj_output\n[1x1x4096]", style=solid, color="#555555", penwidth=1.0];
  "layer0_input" -> "layer0_attn_residual_add" [label="residual\n[1x1x4096]", style=dashed, color="#E85454", penwidth=2.0];
  "layer0_attn_residual_add" -> "layer0_gate_proj" [label="post_attn\n[1x1x4096]", style=solid, color="#555555", penwidth=1.0];
  "layer0_attn_residual_add" -> "layer0_up_proj" [label="post_attn\n[1x1x4096]", style=solid, color="#555555", penwidth=1.0];
  "layer0_gate_proj" -> "layer0_down_proj" [label="gate_output\n[1x1x14336]", style=solid, color="#555555", penwidth=1.0];
  "layer0_up_proj" -> "layer0_down_proj" [label="up_output\n[1x1x14336]", style=solid, color="#555555", penwidth=1.0];
  "layer0_down_proj" -> "layer0_mlp_residual_add" [label="down_proj_ou...\n[1x1x4096]", style=solid, color="#555555", penwidth=1.0];
  "layer0_attn_residual_add" -> "layer0_mlp_residual_add" [label="residual\n[1x1x4096]", style=dashed, color="#E85454", penwidth=2.0];
  "layer0_mlp_residual_add" -> "lm_head" [label="final_hidden\n[1x1x4096]", style=solid, color="#555555", penwidth=1.0];

  // Repeat block: decoder_layer x32
  "repeat_note" [label="Repeated x32 layers", shape=note, fillcolor="#FFFFCC", style="filled", fontsize=11, fontcolor="#666666"];
  "layer0_mlp_residual_add" -> "repeat_note" [style=dotted, color="#999999", arrowhead=none];

  subgraph cluster_legend {
    label="Legend";
    fontsize=11;
    style="rounded";
    color="#CCCCCC";
    bgcolor="#F8F8F8";
    "leg_linear" [label="linear", shape=box, fillcolor="#4A90D9", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_attn_qk" [label="attn qk", shape=diamond, fillcolor="#E8963E", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_softmax_max" [label="softmax max", shape=parallelogram, fillcolor="#F5C842", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_softmax_exp" [label="softmax exp", shape=parallelogram, fillcolor="#F0B429", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_softmax_sum" [label="softmax sum", shape=parallelogram, fillcolor="#E8963E", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_softmax_div" [label="softmax div", shape=parallelogram, fillcolor="#D4832C", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_attn_v" [label="attn v", shape=diamond, fillcolor="#D4722C", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_residual_add" [label="residual add", shape=circle, fillcolor="#E85454", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_linear" -> "leg_attn_qk" -> "leg_softmax_max" -> "leg_softmax_exp" -> "leg_softmax_sum" -> "leg_softmax_div" -> "leg_attn_v" -> "leg_residual_add" [style=invis];
    "leg_skip_src" [label="", shape=point, width=0.1];
    "leg_skip_dst" [label="skip conn.", shape=plaintext, fontsize=9];
    "leg_skip_src" -> "leg_skip_dst" [style=dashed, color="#E85454", penwidth=2.0];
    "leg_residual_add" -> "leg_skip_src" [style=invis];
  }
}