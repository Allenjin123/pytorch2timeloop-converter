digraph G {
  label="qwen3_235b_a22b_decode_kv2048";
  labelloc="t";
  fontsize=16;
  fontname="Helvetica";
  rankdir=TB;
  nodesep=0.4;
  ranksep=0.6;
  node [fontname="Helvetica", fontsize=10, style="filled,rounded", penwidth=1.5];
  edge [fontname="Helvetica", fontsize=8, color="#555555"];

  { rank=same; "layer0_k_proj" "layer0_q_proj" "layer0_v_proj" }
  { rank=same; "layer0_expert_repr_gate_proj" "layer0_expert_repr_up_proj" }

  "layer0_input" [label="input", shape=ellipse, fillcolor="#E8E8E8", style="filled"];
  "layer0_k_proj" [label="k_proj", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_q_proj" [label="q_proj", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_attn_qk" [label="attn_qk", shape=diamond, fillcolor="#E8963E", fontcolor="white"];
  "layer0_v_proj" [label="v_proj", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_attn_v" [label="attn_v", shape=diamond, fillcolor="#D4722C", fontcolor="white"];
  "layer0_o_proj" [label="o_proj", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_attn_residual_add" [label="attn_residual_add", shape=circle, fillcolor="#E85454", width=0.3, height=0.3, fixedsize=true, fontsize=14];
  "layer0_router" [label="router", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_expert_repr_gate_proj" [label="expert_repr_gate_proj", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_expert_repr_up_proj" [label="expert_repr_up_proj", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_expert_repr_down_proj" [label="expert_repr_down_proj", shape=box, fillcolor="#4A90D9", fontcolor="white"];
  "layer0_moe_combine" [label="moe_combine", shape=hexagon, fillcolor="#9B59B6", fontcolor="white"];
  "layer0_mlp_residual_add" [label="mlp_residual_add", shape=circle, fillcolor="#E85454", width=0.3, height=0.3, fixedsize=true, fontsize=14];
  "lm_head" [label="lm_head", shape=box, fillcolor="#4A90D9", fontcolor="white"];

  "layer0_input" -> "layer0_q_proj" [style=solid, color="#555555", penwidth=1.0];
  "layer0_input" -> "layer0_k_proj" [style=solid, color="#555555", penwidth=1.0];
  "layer0_input" -> "layer0_v_proj" [style=solid, color="#555555", penwidth=1.0];
  "layer0_q_proj" -> "layer0_attn_qk" [style=solid, color="#555555", penwidth=1.0];
  "layer0_k_proj" -> "layer0_attn_qk" [style=solid, color="#555555", penwidth=1.0];
  "layer0_attn_qk" -> "layer0_attn_v" [style=solid, color="#555555", penwidth=1.0];
  "layer0_v_proj" -> "layer0_attn_v" [style=solid, color="#555555", penwidth=1.0];
  "layer0_attn_v" -> "layer0_o_proj" [style=solid, color="#555555", penwidth=1.0];
  "layer0_o_proj" -> "layer0_attn_residual_add" [style=solid, color="#555555", penwidth=1.0];
  "layer0_input" -> "layer0_attn_residual_add" [style=dashed, color="#E85454", penwidth=2.0];
  "layer0_attn_residual_add" -> "layer0_router" [style=solid, color="#555555", penwidth=1.0];
  "layer0_router" -> "layer0_expert_repr_gate_proj" [style=solid, color="#555555", penwidth=1.0];
  "layer0_router" -> "layer0_expert_repr_up_proj" [style=solid, color="#555555", penwidth=1.0];
  "layer0_expert_repr_gate_proj" -> "layer0_expert_repr_down_proj" [style=solid, color="#555555", penwidth=1.0];
  "layer0_expert_repr_up_proj" -> "layer0_expert_repr_down_proj" [style=solid, color="#555555", penwidth=1.0];
  "layer0_expert_repr_down_proj" -> "layer0_moe_combine" [style=solid, color="#555555", penwidth=1.0];
  "layer0_moe_combine" -> "layer0_mlp_residual_add" [style=solid, color="#555555", penwidth=1.0];
  "layer0_attn_residual_add" -> "layer0_mlp_residual_add" [style=dashed, color="#E85454", penwidth=2.0];
  "layer0_mlp_residual_add" -> "lm_head" [style=solid, color="#555555", penwidth=1.0];

  // Repeat block: decoder_layer x94
  "repeat_note" [label="Repeated x94 layers", shape=note, fillcolor="#FFFFCC", style="filled", fontsize=11, fontcolor="#666666"];
  "layer0_mlp_residual_add" -> "repeat_note" [style=dotted, color="#999999", arrowhead=none];

  subgraph cluster_legend {
    label="Legend";
    fontsize=11;
    style="rounded";
    color="#CCCCCC";
    bgcolor="#F8F8F8";
    "leg_linear" [label="linear", shape=box, fillcolor="#4A90D9", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_attn_qk" [label="attn qk", shape=diamond, fillcolor="#E8963E", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_attn_v" [label="attn v", shape=diamond, fillcolor="#D4722C", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_residual_add" [label="residual add", shape=circle, fillcolor="#E85454", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_moe_combine" [label="moe combine", shape=hexagon, fillcolor="#9B59B6", fontcolor="white", fontsize=9, width=1.2, height=0.25];
    "leg_linear" -> "leg_attn_qk" -> "leg_attn_v" -> "leg_residual_add" -> "leg_moe_combine" [style=invis];
    "leg_skip_src" [label="", shape=point, width=0.1];
    "leg_skip_dst" [label="skip conn.", shape=plaintext, fontsize=9];
    "leg_skip_src" -> "leg_skip_dst" [style=dashed, color="#E85454", penwidth=2.0];
    "leg_moe_combine" -> "leg_skip_src" [style=invis];
  }
}